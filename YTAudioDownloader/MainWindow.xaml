<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="YTAudioDownloader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YTAudioDownloader"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="YouTube Audio Downloader">

    <Grid RequestedTheme="Light">
        <Grid.Background>
            <SolidColorBrush Color="#FFF6F8FA"/>
        </Grid.Background>

        <Grid.Resources>
            <!-- Sidebar navigation RadioButton style -->
            <Style x:Key="SidebarNavStyle" TargetType="RadioButton">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="12,9"/>
                <Setter Property="FocusVisualMargin" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid>
                                <Border x:Name="CheckBg" CornerRadius="6" Background="Transparent"/>
                                <Border x:Name="HoverOverlay" CornerRadius="6" Background="Transparent"/>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Padding="{TemplateBinding Padding}"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="Center"
                                                  Foreground="#FF57606A"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="CheckBg.Background" Value="#FFDEF7FF"/>
                                                <Setter Target="ContentPresenter.Foreground" Value="#FF0969DA"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Unchecked">
                                            <VisualState.Setters>
                                                <Setter Target="CheckBg.Background" Value="Transparent"/>
                                                <Setter Target="ContentPresenter.Foreground" Value="#FF57606A"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Indeterminate"/>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="HoverOverlay.Background" Value="#15000000"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="HoverOverlay.Background" Value="#25000000"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="ContentPresenter.Opacity" Value="0.4"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="White">
            <Border BorderBrush="#FFD0D7DE" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="16,0">
                    <Border Width="28" Height="28" CornerRadius="6" Background="#FF0969DA">
                        <FontIcon Glyph="&#xE189;" FontSize="14" Foreground="White"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="YouTube Audio Downloader" FontWeight="SemiBold" FontSize="13"
                               Foreground="#FF24292F" VerticalAlignment="Center"/>
                    <Border CornerRadius="10" Background="#FFEAEEF2" Padding="7,2">
                        <TextBlock Text="v2.1.0" FontSize="10" FontWeight="Medium" Foreground="#FF57606A"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Layout: Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="White" BorderBrush="#FFD0D7DE" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="0" Padding="12,14,12,8" Spacing="2">
                        <RadioButton x:Name="NavDownload"
                                     GroupName="MainNav"
                                     IsChecked="True"
                                     Checked="OnNavChecked"
                                     Tag="download"
                                     Style="{StaticResource SidebarNavStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE896;" FontSize="14"/>
                                <TextBlock Text="Descargar" FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavQueue"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="queue"
                                     Style="{StaticResource SidebarNavStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE90B;" FontSize="14"/>
                                <TextBlock Text="Cola" FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavLibrary"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="library"
                                     Style="{StaticResource SidebarNavStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xED25;" FontSize="14"/>
                                <TextBlock Text="Biblioteca" FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavSettings"
                                     GroupName="MainNav"
                                     Checked="OnNavChecked"
                                     Tag="settings"
                                     Style="{StaticResource SidebarNavStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE713;" FontSize="14"/>
                                <TextBlock Text="Ajustes" FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Sidebar Footer -->
                    <Border Grid.Row="1" BorderBrush="#FFD0D7DE" BorderThickness="0,1,0,0" Padding="12">
                        <Border CornerRadius="8" Background="#FFEAEEF2" Padding="12">
                            <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="13" Foreground="#FF57606A"/>
                                    <TextBlock Text="Open Source" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FF57606A"/>
                                </StackPanel>
                                <TextBlock Text="Proyecto de código abierto. Contribuye en GitHub."
                                           FontSize="11" Foreground="#FF57606A" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <!-- Content Frame -->
            <Frame x:Name="ContentFrame" Grid.Column="1" Background="Transparent"/>
        </Grid>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YTAudioDownloader.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" MaxWidth="820">

            <!-- Title -->
            <StackPanel Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="Ajustes" FontSize="22" FontWeight="Bold" Foreground="#FF24292F"/>
                <TextBlock Text="Configura la aplicación según tus preferencias"
                           FontSize="13" Foreground="#FF57606A"/>
            </StackPanel>

            <!-- General Section -->
            <Border Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;" FontSize="16" Foreground="#FF0969DA" VerticalAlignment="Center"/>
                        <TextBlock Text="General" FontWeight="SemiBold" FontSize="14" Foreground="#FF24292F"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="#FFD0D7DE"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Carpeta de descargas" FontSize="13" FontWeight="Medium"
                                   Foreground="#FF24292F"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputFolderBox" IsReadOnly="True"
                                     Foreground="#FF57606A" Background="#FFFAFAFA"
                                     BorderBrush="#FFD0D7DE" CornerRadius="6"/>
                            <Button Grid.Column="1" Click="OnBrowseFolderClick"
                                    Content="Examinar" CornerRadius="6" Padding="12,8"
                                    Background="White" BorderBrush="#FFD0D7DE" Foreground="#FF24292F"/>
                        </Grid>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Crear subcarpetas por artista" FontSize="13"
                                       FontWeight="Medium" Foreground="#FF24292F"/>
                            <TextBlock Text="Organiza los archivos en carpetas separadas por artista"
                                       FontSize="11" Foreground="#FF57606A"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="ArtistSubfolderSwitch" Grid.Column="1"
                                     OnContent="" OffContent="" VerticalAlignment="Center"
                                     Toggled="OnArtistSubfolderToggled"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Abrir carpeta al completar" FontSize="13"
                                       FontWeight="Medium" Foreground="#FF24292F"/>
                            <TextBlock Text="Abre el explorador de archivos automáticamente"
                                       FontSize="11" Foreground="#FF57606A"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="OpenFolderSwitch" Grid.Column="1"
                                     OnContent="" OffContent="" VerticalAlignment="Center"
                                     Toggled="OnOpenFolderToggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Downloads Section -->
            <Border Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="16" Foreground="#FF0969DA" VerticalAlignment="Center"/>
                        <TextBlock Text="Descargas" FontWeight="SemiBold" FontSize="14" Foreground="#FF24292F"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="#FFD0D7DE"/>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Formato predeterminado" FontSize="12" FontWeight="Medium"
                                       Foreground="#FF24292F"/>
                            <ComboBox x:Name="DefaultFormatCombo" SelectedIndex="0"
                                      HorizontalAlignment="Stretch"
                                      Background="White" BorderBrush="#FFD0D7DE" CornerRadius="6"
                                      SelectionChanged="OnDefaultFormatChanged">
                                <ComboBoxItem Content="MP3"/>
                                <ComboBoxItem Content="FLAC"/>
                                <ComboBoxItem Content="WAV"/>
                                <ComboBoxItem Content="AAC"/>
                                <ComboBoxItem Content="Opus"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="Calidad predeterminada" FontSize="12" FontWeight="Medium"
                                       Foreground="#FF24292F"/>
                            <ComboBox x:Name="DefaultQualityCombo" SelectedIndex="3"
                                      HorizontalAlignment="Stretch"
                                      Background="White" BorderBrush="#FFD0D7DE" CornerRadius="6"
                                      SelectionChanged="OnDefaultQualityChanged">
                                <ComboBoxItem Content="128 kbps"/>
                                <ComboBoxItem Content="192 kbps"/>
                                <ComboBoxItem Content="256 kbps"/>
                                <ComboBoxItem Content="320 kbps"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Descargas simultáneas" FontSize="12" FontWeight="Medium"
                                   Foreground="#FF24292F"/>
                        <ComboBox x:Name="SimultaneousCombo" SelectedIndex="2" Width="120"
                                  HorizontalAlignment="Left"
                                  Background="White" BorderBrush="#FFD0D7DE" CornerRadius="6"
                                  SelectionChanged="OnSimultaneousChanged">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="5"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Performance Section -->
            <Border Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE9D9;" FontSize="16" Foreground="#FF0969DA" VerticalAlignment="Center"/>
                        <TextBlock Text="Rendimiento" FontWeight="SemiBold" FontSize="14" Foreground="#FF24292F"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="#FFD0D7DE"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Usar aceleración GPU" FontSize="13"
                                       FontWeight="Medium" Foreground="#FF24292F"/>
                            <TextBlock Text="Acelera la conversión de audio usando la GPU"
                                       FontSize="11" Foreground="#FF57606A"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="GpuAccelSwitch" Grid.Column="1"
                                     OnContent="" OffContent="" VerticalAlignment="Center"
                                     Toggled="OnGpuAccelToggled"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Modo bajo consumo" FontSize="13"
                                       FontWeight="Medium" Foreground="#FF24292F"/>
                            <TextBlock Text="Reduce el uso de recursos del sistema"
                                       FontSize="11" Foreground="#FF57606A"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="LowPowerSwitch" Grid.Column="1"
                                     OnContent="" OffContent="" VerticalAlignment="Center"
                                     Toggled="OnLowPowerToggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Metadata Section -->
            <Border Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8F9;" FontSize="16" Foreground="#FF0969DA" VerticalAlignment="Center"/>
                        <TextBlock Text="Metadatos" FontWeight="SemiBold" FontSize="14" Foreground="#FF24292F"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="#FFD0D7DE"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Auto-detectar metadatos" FontSize="13"
                                       FontWeight="Medium" Foreground="#FF24292F"/>
                            <TextBlock Text="Obtener artista, álbum y portada automáticamente de MusicBrainz e iTunes"
                                       FontSize="11" Foreground="#FF57606A"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoMetadataSwitch" Grid.Column="1"
                                     OnContent="" OffContent="" VerticalAlignment="Center"
                                     Toggled="OnAutoMetadataToggled"/>
                    </Grid>

                    <Border CornerRadius="6" Background="#FFF6F8FA" BorderBrush="#FFD0D7DE"
                            BorderThickness="1" Padding="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="#FF57606A"/>
                            <TextBlock Text="Metadatos obtenidos de MusicBrainz + iTunes. La portada del video de YouTube se usa como alternativa."
                                       FontSize="11" Foreground="#FF57606A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- About Section -->
            <Border Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE946;" FontSize="16" Foreground="#FF0969DA" VerticalAlignment="Center"/>
                        <TextBlock Text="Acerca de" FontWeight="SemiBold" FontSize="14" Foreground="#FF24292F"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="#FFD0D7DE"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="YouTube Audio Downloader" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FF24292F"/>
                            <TextBlock Text="Versión 2.1.0" FontSize="12" Foreground="#FF57606A"/>
                            <TextBlock Text="Descarga y convierte audio de YouTube con metadatos automáticos."
                                       FontSize="12" Foreground="#FF57606A" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                            <Button Content="GitHub" CornerRadius="6" Padding="14,8"
                                    Background="White" BorderBrush="#FFD0D7DE" Foreground="#FF24292F"
                                    Click="OnGitHubClick"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

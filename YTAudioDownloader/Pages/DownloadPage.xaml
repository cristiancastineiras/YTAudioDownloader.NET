<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YTAudioDownloader.Pages.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YTAudioDownloader.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FocusVisualMargin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="White"/>
                                            <Setter Target="Content.Foreground" Value="#FF24292F"/>
                                            <Setter Target="Content.FontWeight" Value="SemiBold"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="Transparent"/>
                                            <Setter Target="Content.Foreground" Value="#FF57606A"/>
                                            <Setter Target="Content.FontWeight" Value="Normal"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="Content"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Foreground="#FF57606A"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF1F883D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FF1A7F37"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FF116329"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FFD8DEE4"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="#FF57606A"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnalyzeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF0969DA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FF0860C8"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FF0550AA"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FFD8DEE4"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="#FF57606A"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" MaxWidth="820">

            <!-- Title -->
            <StackPanel Spacing="4">
                <TextBlock Text="Descargar Audio" FontSize="22" FontWeight="Bold" Foreground="#FF24292F"/>
                <TextBlock Text="Pega una URL de YouTube para extraer y descargar el audio"
                           FontSize="13" Foreground="#FF57606A"/>
            </StackPanel>

            <!-- URL Input Card -->
            <Border Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE71B;" FontSize="14" Foreground="#FF0969DA"/>
                        <TextBlock Text="URL del Video" FontWeight="Medium" FontSize="13" Foreground="#FF24292F"/>
                    </StackPanel>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="VideoUrlTextBox"
                                 PlaceholderText="https://www.youtube.com/watch?v=..."
                                 Background="White"
                                 BorderBrush="#FFD0D7DE"
                                 CornerRadius="6"
                                 TextChanged="OnUrlTextChanged"/>
                        <Button x:Name="AnalyzeButton" Grid.Column="1" Click="OnAnalyzeClick"
                                Style="{StaticResource AnalyzeButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="AnalyzeIcon" Glyph="&#xE8F9;" FontSize="13" Foreground="White"/>
                                <TextBlock x:Name="AnalyzeText" Text="Analizar" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Video Preview Card (hidden by default) -->
            <Border x:Name="VideoPreviewCard" Visibility="Collapsed"
                    Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8">
                <Grid Padding="16" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="100" Height="68" CornerRadius="6" Background="#FFEAEEF2">
                        <FontIcon Glyph="&#xE8D6;" FontSize="28" Foreground="#FF57606A"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <TextBlock x:Name="PreviewTitle" FontWeight="SemiBold" FontSize="14"
                                   Foreground="#FF24292F" TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="PreviewArtist" FontSize="12" Foreground="#FF57606A"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border CornerRadius="4" Background="#FFDEF7FF" Padding="6,2">
                                <TextBlock x:Name="PreviewDuration" FontSize="11" FontWeight="Medium"
                                           Foreground="#FF0969DA"/>
                            </Border>
                            <Border CornerRadius="4" Background="#FFEAEEF2" Padding="6,2">
                                <TextBlock Text="YouTube" FontSize="11" FontWeight="Medium" Foreground="#FF57606A"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Settings Tabs Card -->
            <Border Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="14">
                    <!-- Tab Headers -->
                    <Border Background="#FFEAEEF2" CornerRadius="6" Padding="2" Height="34">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="TabFormato" GroupName="DLTabs" IsChecked="True"
                                         Checked="OnTabChecked" Tag="formato"
                                         Style="{StaticResource TabButtonStyle}" Content="Formato"/>
                            <RadioButton x:Name="TabMetadata" Grid.Column="1" GroupName="DLTabs"
                                         Checked="OnTabChecked" Tag="metadata"
                                         Style="{StaticResource TabButtonStyle}" Content="Metadatos"/>
                            <RadioButton x:Name="TabSalida" Grid.Column="2" GroupName="DLTabs"
                                         Checked="OnTabChecked" Tag="salida"
                                         Style="{StaticResource TabButtonStyle}" Content="Salida"/>
                        </Grid>
                    </Border>

                    <!-- FORMAT TAB -->
                    <Grid x:Name="FormatoTabContent" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Formato de Audio" FontSize="12" FontWeight="Medium" Foreground="#FF24292F"/>
                            <ComboBox x:Name="FormatComboBox" SelectedIndex="0"
                                      HorizontalAlignment="Stretch"
                                      Background="White" BorderBrush="#FFD0D7DE" CornerRadius="6">
                                <ComboBoxItem Content="MP3 - Compatible universal" Tag="Mp3"/>
                                <ComboBoxItem Content="FLAC - Sin pérdida" Tag="Flac"/>
                                <ComboBoxItem Content="WAV - Sin comprimir" Tag="Wav"/>
                                <ComboBoxItem Content="AAC - Alta eficiencia" Tag="Aac"/>
                                <ComboBoxItem Content="Opus - Código abierto" Tag="Opus"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="Calidad (kbps)" FontSize="12" FontWeight="Medium" Foreground="#FF24292F"/>
                            <ComboBox x:Name="QualityComboBox" SelectedIndex="3"
                                      HorizontalAlignment="Stretch"
                                      Background="White" BorderBrush="#FFD0D7DE" CornerRadius="6">
                                <ComboBoxItem Content="128 kbps - Básica" Tag="128"/>
                                <ComboBoxItem Content="192 kbps - Buena" Tag="192"/>
                                <ComboBoxItem Content="256 kbps - Alta" Tag="256"/>
                                <ComboBoxItem Content="320 kbps - Máxima" Tag="320"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- METADATA TAB -->
                    <StackPanel x:Name="MetadataTabContent" Spacing="12" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8F9;" FontSize="16" Foreground="#FF0969DA"/>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Auto-detectar metadatos" FontWeight="Medium"
                                               FontSize="13" Foreground="#FF24292F"/>
                                    <TextBlock Text="Obtener artista, álbum y portada automáticamente"
                                               FontSize="11" Foreground="#FF57606A"/>
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch x:Name="AutoMetadataSwitch" Grid.Column="1"
                                         IsOn="True" Toggled="OnAutoMetadataToggled"
                                         OnContent="" OffContent=""
                                         VerticalAlignment="Center"/>
                        </Grid>
                        <Grid x:Name="ManualMetadataGrid" Visibility="Collapsed" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Artista" FontSize="12" FontWeight="Medium" Foreground="#FF24292F"/>
                                <TextBox x:Name="ArtistTextBox" PlaceholderText="Nombre del artista"
                                         Background="White" BorderBrush="#FFD0D7DE" CornerRadius="6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Álbum" FontSize="12" FontWeight="Medium" Foreground="#FF24292F"/>
                                <TextBox x:Name="AlbumTextBox" PlaceholderText="Nombre del álbum"
                                         Background="White" BorderBrush="#FFD0D7DE" CornerRadius="6"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- SALIDA TAB -->
                    <StackPanel x:Name="SalidaTabContent" Spacing="8" Visibility="Collapsed">
                        <TextBlock Text="Carpeta de destino" FontSize="12" FontWeight="Medium" Foreground="#FF24292F"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputFolderTextBox" IsReadOnly="True"
                                     Foreground="#FF57606A" Background="#FFFAFAFA"
                                     BorderBrush="#FFD0D7DE" CornerRadius="6"/>
                            <Button Grid.Column="1" Click="OnBrowseFolderClick"
                                    CornerRadius="6" Padding="12,8" Content="Examinar"
                                    Background="White" BorderBrush="#FFD0D7DE" Foreground="#FF24292F"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                            <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="#FF57606A"/>
                            <TextBlock Text="Los archivos se guardarán en esta carpeta"
                                       FontSize="11" Foreground="#FF57606A"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Progress Card (shown during download) -->
            <Border x:Name="ProgressCard" Visibility="Collapsed"
                    Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <ProgressRing x:Name="StatusProgressRing" IsActive="True" Width="18" Height="18"
                                      Foreground="#FF0969DA"/>
                        <TextBlock x:Name="StatusTextBlock" FontSize="13" Foreground="#FF0969DA"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ProgressBar x:Name="DownloadProgressBar" Minimum="0" Maximum="100" Value="0"
                                 Height="6" CornerRadius="3" Foreground="#FF0969DA"
                                 Background="#FFEAEEF2"/>
                </StackPanel>
            </Border>

            <!-- Error message -->
            <Border x:Name="ErrorCard" Visibility="Collapsed"
                    Background="#FFFFEBE9" BorderBrush="#FFFFD7D5" BorderThickness="1"
                    CornerRadius="8" Padding="14">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xEA39;" FontSize="16" Foreground="#FFCF222E" VerticalAlignment="Top"/>
                    <TextBlock x:Name="ErrorTextBlock" Foreground="#FFCF222E" FontSize="12"
                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Download Button -->
            <Button x:Name="DownloadButton" Click="OnDownloadClick"
                    IsEnabled="False"
                    Style="{StaticResource PrimaryButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="White"/>
                    <TextBlock Text="Descargar" FontWeight="SemiBold" FontSize="14"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YTAudioDownloader.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:YTAudioDownloader.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="ViewToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FFD8DEE4"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="#FFC8D0D8"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Biblioteca" FontSize="22" FontWeight="Bold" Foreground="#FF24292F"/>
                <TextBlock x:Name="CountLabel" FontSize="13" Foreground="#FF57606A"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <!-- Search -->
                <Grid>
                    <TextBox x:Name="SearchBox" PlaceholderText="Buscar..."
                             Width="220" Background="White" BorderBrush="#FFD0D7DE"
                             CornerRadius="6" Padding="36,8,8,8"
                             TextChanged="OnSearchTextChanged"/>
                    <FontIcon Glyph="&#xE721;" FontSize="13" Foreground="#FF57606A"
                              HorizontalAlignment="Left" VerticalAlignment="Center"
                              Margin="12,0,0,0" IsHitTestVisible="False"/>
                </Grid>
                <!-- View toggle -->
                <Border CornerRadius="6" Background="#FFEAEEF2" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="GridViewBtn" Click="OnGridViewClick"
                                Style="{StaticResource ViewToggleButtonStyle}"
                                Background="White">
                            <FontIcon Glyph="&#xE8A9;" FontSize="13" Foreground="#FF24292F"/>
                        </Button>
                        <Button x:Name="ListViewBtn" Click="OnListViewClick"
                                Style="{StaticResource ViewToggleButtonStyle}"
                                Background="Transparent">
                            <FontIcon Glyph="&#xE8FD;" FontSize="13" Foreground="#FF57606A"/>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
            <!-- Grid View -->
            <ItemsRepeater x:Name="GridItemsControl" Visibility="Visible">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="175" MinItemHeight="210"
                                       ItemsStretch="None"
                                       MinColumnSpacing="12" MinRowSpacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:DownloadQueueItem">
                        <Border Width="175" Background="White" BorderBrush="#FFD0D7DE"
                                BorderThickness="1" CornerRadius="8" Padding="0">
                            <StackPanel>
                                <Border Height="120" CornerRadius="8,8,0,0" Background="#FFEAEEF2">
                                    <FontIcon Glyph="&#xE8D6;" FontSize="40" Foreground="#FF57606A"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Padding="12,10">
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                               FontWeight="Medium" FontSize="13" Foreground="#FF24292F"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Artist, Mode=OneWay}"
                                               FontSize="12" Foreground="#FF57606A" Margin="0,2,0,6"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border CornerRadius="4" Background="#FFEAEEF2" Padding="6,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{x:Bind Format, Mode=OneWay}"
                                                   FontSize="10" FontWeight="Medium" Foreground="#FF57606A"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- List View -->
            <Border x:Name="ListViewContainer" Visibility="Collapsed"
                    Background="White" BorderBrush="#FFD0D7DE" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <!-- Header row -->
                    <Grid Padding="16,12" BorderBrush="#FFD0D7DE" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Título" FontSize="12" FontWeight="Medium" Foreground="#FF57606A"/>
                        <TextBlock Grid.Column="1" Text="Artista" FontSize="12" FontWeight="Medium" Foreground="#FF57606A"/>
                        <TextBlock Grid.Column="2" Text="Formato" FontSize="12" FontWeight="Medium" Foreground="#FF57606A"/>
                        <TextBlock Grid.Column="3" Text="Duración" FontSize="12" FontWeight="Medium" Foreground="#FF57606A"/>
                    </Grid>
                    <ItemsControl x:Name="ListItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DownloadQueueItem">
                                <Grid Padding="16,12" BorderBrush="#FFD0D7DE" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Width="34" Height="34" CornerRadius="4" Background="#FFEAEEF2">
                                            <FontIcon Glyph="&#xE8D6;" FontSize="14" Foreground="#FF57606A"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                   FontWeight="Medium" FontSize="13" Foreground="#FF24292F"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Artist, Mode=OneWay}"
                                               FontSize="13" Foreground="#FF57606A" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Column="2" CornerRadius="4" Background="#FFEAEEF2"
                                            Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Format, Mode=OneWay}"
                                                   FontSize="11" FontWeight="Medium" Foreground="#FF57606A"/>
                                    </Border>
                                    <TextBlock Grid.Column="3" Text="{x:Bind Duration, Mode=OneWay}"
                                               FontSize="13" Foreground="#FF57606A" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            </Grid>
        </ScrollViewer>

        <!-- Empty state overlay -->
        <StackPanel x:Name="EmptyState" Grid.Row="1" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <Border Width="64" Height="64" CornerRadius="32" Background="#FFEAEEF2"
                    HorizontalAlignment="Center">
                <FontIcon Glyph="&#xED25;" FontSize="32" Foreground="#FF57606A"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="Biblioteca vacía" FontWeight="Medium" FontSize="14"
                           Foreground="#FF24292F" HorizontalAlignment="Center"/>
                <TextBlock Text="Las canciones descargadas aparecerán aquí" FontSize="13"
                           Foreground="#FF57606A" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
